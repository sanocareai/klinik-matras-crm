{
  "expo": {
    "name": "Klinik Matras CRM",
    "slug": "klinik-matras-crm",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.sanomatrassehat.salesapp",
      "versionCode": 3,
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#075E54",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#25D366"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikasi butuh akses galeri untuk kirim foto ke pelanggan",
          "cameraPermission": "Aplikasi butuh akses kamera untuk kirim foto ke pelanggan"
        }
      ],
      "expo-font",
      "expo-sharing",
      [
        "expo-audio",
        {
          "microphonePermission": "Aplikasi butuh akses mikrofon untuk merekam pesan suara ke pelanggan"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "backgroundColor": "#F8FAFC",
          "resizeMode": "contain",
          "imageWidth": 180
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "d3d84ffc-6fdb-4525-bd47-e04a844fa37b"
      }
    }
  }
}
